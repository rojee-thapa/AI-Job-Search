# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
JWT_SECRET=change-me-in-production-use-strong-random-string
JWT_EXPIRES_IN=7d

# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_DB=aijobagent
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aijobagent

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── AI APIs ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
PERPLEXITY_API_KEY=pplx-...
PERPLEXITY_MODEL=llama-3.1-sonar-large-128k-online

# ─── Email ───────────────────────────────────────────────────────────────────
# Choose one: sendgrid | gmail
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=SG.xxx
SENDGRID_FROM_EMAIL=jobs@yourdomain.com
SENDGRID_FROM_NAME=AI Job Agent

# Gmail OAuth (alternative)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_USER_EMAIL=

# ─── Google Sheets ───────────────────────────────────────────────────────────
GOOGLE_SHEETS_CREDENTIALS_JSON={"type":"service_account",...}
GOOGLE_SHEETS_SPREADSHEET_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms

# ─── Frontend ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# ─── Rate Limiting & Automation ──────────────────────────────────────────────
MAX_DAILY_APPLICATIONS=20
APPLICATION_DELAY_MS=5000
FOLLOW_UP_DAYS=10
ALERT_HOUR=8

# ─── Scraper Settings ────────────────────────────────────────────────────────
SCRAPER_HEADLESS=true
SCRAPER_TIMEOUT_MS=30000
